{
  "name": "winks-cms",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' run dev",
    "dev:api": "pnpm --filter @winks/api dev",
    "dev:web": "pnpm --filter @winks/web dev",
    "build": "pnpm --recursive run build",
    "typecheck": "pnpm --recursive run typecheck"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
